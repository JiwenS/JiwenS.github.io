---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostRecommendations from "../../components/PostRecommendations.astro";
import { formatDate } from "../../lib/date";
import { formatReadingTime } from "../../lib/reading-time";
import { getAdjacentPosts, getPublishedPosts, getRecommendedPosts } from "../../lib/posts";
import { AUTHOR_LINKS, AUTHOR_NAME, SITE_URL, getCanonicalUrl } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const { previousPost, nextPost } = getAdjacentPosts(posts, post.id);
const recommendedPosts = getRecommendedPosts(posts, post);
const canonicalUrl = post.data.canonicalUrl || getCanonicalUrl(`/post/${post.id}/`);
const formatTagLabel = (tag: string) =>
  tag
    .split("-")
    .map((part) => (part === "ai" ? "AI" : part.charAt(0).toUpperCase() + part.slice(1)))
    .join(" ");
const articleJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    url: canonicalUrl,
    datePublished: post.data.publishedAt.toISOString(),
    dateModified: post.data.updatedAt.toISOString(),
    inLanguage: "en",
    keywords: post.data.tags,
    author: {
      "@type": "Person",
      name: AUTHOR_NAME,
      url: SITE_URL,
      sameAs: AUTHOR_LINKS,
    },
    publisher: {
      "@type": "Person",
      name: AUTHOR_NAME,
      url: SITE_URL,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: SITE_URL,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: post.data.title,
        item: canonicalUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalUrl={canonicalUrl}
  image={post.data.heroImage}
  type="article"
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  tags={post.data.tags}
  jsonLd={articleJsonLd}
>
  <article class="post-detail" style={`--color-theme: var(--theme-${post.data.themeColor});`}>
    <a class="back-link" href="/">&larr; Home</a>

    <header class="post-header">
      <ul class="tags" aria-label="Post tags">
        {post.data.tags.map((tag) => <li>{formatTagLabel(tag)}</li>)}
      </ul>
      <h1 transition:name={`post-title-${post.id}`}>{post.data.title}</h1>
      <p class="dek">{post.data.subtitle || post.data.description}</p>
      <p class="meta post-meta">
        <span>By Jiwen Song</span>
        <span class="meta-separator" aria-hidden="true"></span>
        <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
        {
          post.data.updatedAt.getTime() !== post.data.publishedAt.getTime() && (
            <>
              <span class="meta-separator" aria-hidden="true" />
              <span>Updated</span>
              <time datetime={post.data.updatedAt.toISOString()}>
                {formatDate(post.data.updatedAt)}
              </time>
            </>
          )
        }
        <span class="meta-separator" aria-hidden="true"></span>
        <span>{formatReadingTime(post.readingTimeMinutes)}</span>
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    <nav class="post-navigation" aria-label="Adjacent posts">
      {
        previousPost && (
          <a class="post-navigation-link previous-post-link" href={`/post/${previousPost.id}/`}>
            <span>Previous Post</span>
            {previousPost.data.title}
          </a>
        )
      }
      {
        nextPost && (
          <a class="post-navigation-link next-post-link" href={`/post/${nextPost.id}/`}>
            <span>Next Post</span>
            {nextPost.data.title}
          </a>
        )
      }
    </nav>

    <PostRecommendations posts={recommendedPosts} />
  </article>
</BaseLayout>
