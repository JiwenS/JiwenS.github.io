---
import ExternalIconLink from "../components/ExternalIconLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatDateDay, formatDateMonthYear } from "../lib/date";
import { getPublishedPosts } from "../lib/posts";
import {
  AUTHOR_LINKS,
  AUTHOR_NAME,
  AUTHOR_SUMMARY,
  SITE_DESCRIPTION,
  SITE_TITLE,
  SITE_URL,
  getCanonicalUrl,
} from "../lib/site";

const posts = await getPublishedPosts();
const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_TITLE,
    url: SITE_URL,
    description: SITE_DESCRIPTION,
    inLanguage: "en",
    author: {
      "@type": "Person",
      name: AUTHOR_NAME,
      url: SITE_URL,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: AUTHOR_NAME,
    url: SITE_URL,
    sameAs: AUTHOR_LINKS,
    description: AUTHOR_SUMMARY,
  },
];
---

<BaseLayout
  title={SITE_TITLE}
  description={SITE_DESCRIPTION}
  canonicalUrl={getCanonicalUrl("/")}
  jsonLd={homeJsonLd}
>
  <section class="intro" aria-labelledby="site-title">
    <div class="intro-copy">
      <h1 id="site-title">Jiwen Song</h1>
      <p>
        Hey, I'm Jiwen. I spent the past few years working on brokerage clearing
        infrastructure on Wall Street. My work has lived somewhere between
        product design, operational systems, and the financial plumbing most
        users never see.
      </p>
      <p>
        I'm especially interested in how AI changes workflows, interfaces, and
        decision systems, not just demos. A lot of the systems that run modern
        businesses were built long before AI-native workflows existed. That shift
        feels worth paying attention to.
      </p>
      <p>
        Some posts in this space are original essays. Some are observations from
        industry experience. Some are simply ideas worth thinking about.
      </p>
      <p>
        Still learning. Still building. Still exploring what comes next.
      </p>
    </div>
    <aside class="intro-profile" aria-label="Profile links">
      <div class="avatar-placeholder" aria-hidden="true"></div>
      <div class="external-links">
        <ExternalIconLink href="https://github.com/JiwenS" label="GitHub profile" icon="github" />
        <ExternalIconLink
          href="https://www.linkedin.com/in/jiwensong/"
          label="LinkedIn profile"
          icon="linkedin"
        />
      </div>
    </aside>
  </section>

  <section class="post-list" aria-labelledby="latest-posts">
    <h2 id="latest-posts">Latest Posts</h2>
    {
      posts.map((post) => (
        <article
          class="post-list-item"
          style={`--color-theme: var(--theme-${post.data.themeColor});`}
        >
          <time class="post-date-stamp" datetime={post.data.publishedAt.toISOString()}>
            <span class="post-date-day">{formatDateDay(post.data.publishedAt)}</span>
            <span class="post-date-month">{formatDateMonthYear(post.data.publishedAt)}</span>
          </time>
          <div>
            <h3 transition:name={`post-title-${post.id}`}>
              <a href={`/post/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>

